# mymy environment variables for local Docker Compose.
# Change these before using the stack beyond local development.

POSTGRES_USER=mymy
POSTGRES_PASSWORD=mymy
POSTGRES_DB=mymy

# Frontend origin allowed to call the API with credentials.
CORS_ORIGIN=http://localhost:33696

# Host user used by the API container when running local agent CLIs.
HOST_UID=1000
HOST_GID=1000

# Optional when Hermes CLI integration is used from Docker.
# Set these to explicit host paths in your local .env; do not commit them.
# If unset, docker-compose uses empty repo-local ignored directories.
HERMES_HOME=/path/to/hermes/home
HERMES_BIN_DIR=/path/to/hermes/bin
UV_PYTHON_DIR=/path/to/uv/python/cache

# Path inside the API container after HERMES_BIN_DIR is mounted.
HERMES_CLI_PATH=/home/mymy/.local/bin/hermes
