# mymy environment variables for local Docker Compose.
# Change these before using the stack beyond local development.

POSTGRES_USER=mymy
POSTGRES_PASSWORD=mymy
POSTGRES_DB=mymy

# Required only for a fresh install or remediation of the legacy default PIN.
# Use at least 8 characters, start the stack once, then remove this value.
# MYMY_INITIAL_PIN=replace-with-a-private-owner-pin

# Standalone API defaults to 127.0.0.1. A non-loopback bind must use HTTPS,
# secure cookies, and explicit HTTPS CORS origins. Docker Compose already marks
# its host publishing as loopback-only.
# MYMY_BIND_HOST=127.0.0.1

# Frontend origin allowed to call the API with credentials.
CORS_ORIGIN=http://localhost:33696,http://127.0.0.1:33696

# Host user used by the API container when writing the app data volume.
HOST_UID=1000
HOST_GID=1000

# Drive S3 sync provider (optional).
# Leave unset to use only the local Drive volume.
# MYMY_DRIVE_S3_BUCKET=mymy-drive
# MYMY_DRIVE_S3_REGION=us-east-1
# MYMY_DRIVE_S3_ENDPOINT=http://localhost:9000

# Document conversion resource isolation.
MYMY_DOCUMENT_CONVERSION_WORKERS=2
MYMY_DOCUMENT_CONVERSION_QUEUE=2
MYMY_DOCUMENT_CONVERSION_TIMEOUT_SECS=30

# Native content admission and quarantine. Values may lower the compiled
# ceilings but cannot raise them.
MYMY_CONTENT_MAX_ITEM_BYTES=268435456
MYMY_QUARANTINE_MAX_PENDING_BYTES=1073741824
MYMY_QUARANTINE_RETENTION_DAYS=30

# Agent sandbox runner.
# The default Docker Compose mode uses bubblewrap. Set firecracker only after
# providing Firecracker binary, kernel, rootfs, and guest SSH key assets to the
# runner container.
MYMY_SANDBOX_MODE=bubblewrap
# Keep the command inside a nested user namespace. The supported Compose
# profile maps the command to the non-root sandbox UID/GID and was verified
# against the named Drive volume; disabling this also weakens network and
# process-table isolation and is not a supported default profile.
MYMY_SANDBOX_UNSHARE_USER=true
# FIRECRACKER_BIN=/app/data/agent/firecracker-assets/firecracker
# FIRECRACKER_KERNEL_IMAGE=/app/data/agent/firecracker-assets/vmlinux
# FIRECRACKER_ROOTFS_IMAGE=/app/data/agent/firecracker-assets/rootfs.ext4
# FIRECRACKER_SSH_KEY_PATH=/app/data/agent/firecracker-assets/id_rsa
# FIRECRACKER_ASSETS_DIR=./data/firecracker-assets
# FIRECRACKER_GUEST_USER=root
# FIRECRACKER_VCPU_COUNT=1
# FIRECRACKER_MEM_SIZE_MIB=512
# FIRECRACKER_BOOT_TIMEOUT_SECS=30
# The API and runner use a purpose-bound token created in their shared private
# volume. This path must remain outside MYMY_RUNNER_DATA_ROOT so sandbox mounts
# cannot read the control credential.
MYMY_SANDBOX_RUNNER_TOKEN_FILE=/run/mymy/runner-control.token
