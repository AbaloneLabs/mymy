# mymy environment variables for local Docker Compose.
# Change these before using the stack beyond local development.

POSTGRES_USER=mymy
POSTGRES_PASSWORD=mymy
POSTGRES_DB=mymy

# Frontend origin allowed to call the API with credentials.
CORS_ORIGIN=http://localhost:33696

# Host user used by the API container when running local agent CLIs.
HOST_UID=1000
HOST_GID=1000

# Hermes CLI integration (optional).
#
# mymy mounts your host Hermes install into the API container using a
# "path-preserving" strategy: the host path and the in-container path are
# identical. This is required because a Python venv hardcodes absolute paths
# (shebangs, pyvenv.cfg, wrapper exec), so a different in-container path would
# break the venv.
#
# ${HOME} is resolved by docker-compose from YOUR shell environment, so no
# personal path is hardcoded in this repo. For a standard Hermes install
# (~/.hermes, ~/.local/bin, ~/.local/share/uv) you can leave these unset and
# the defaults below will work.
#
# Override ONLY if your Hermes install lives in a non-standard location:
#   HERMES_HOME=/custom/path/to/.hermes
#   HERMES_BIN_DIR=/custom/path/to/bin
#   UV_PYTHON_DIR=/custom/path/to/uv/cache
#
# NOTE: HERMES_HOME/HERMES_BIN_DIR/UV_PYTHON_DIR are the HOST paths; the
# in-container mount target is always the same as the host path
# (path-preserving). Do NOT set HERMES_CLI_PATH here — it is derived from HOME.

# Drive S3 sync provider (optional).
# Leave unset to use only the local Drive volume.
# MYMY_DRIVE_S3_BUCKET=mymy-drive
# MYMY_DRIVE_S3_REGION=us-east-1
# MYMY_DRIVE_S3_ENDPOINT=http://localhost:9000

# Agent sandbox runner.
# The default Docker Compose mode uses bubblewrap. Set firecracker only after
# providing Firecracker binary, kernel, rootfs, and guest SSH key assets to the
# runner container.
MYMY_SANDBOX_MODE=bubblewrap
# Docker named-volume ownership is not user-namespace idmapped by default, so
# Compose keeps bubblewrap user namespaces off while preserving mount/PID/IPC/UTS
# isolation. Enable only with an idmapped/rootfs setup that can write Drive data.
MYMY_SANDBOX_UNSHARE_USER=false
# FIRECRACKER_BIN=/app/data/agent/firecracker-assets/firecracker
# FIRECRACKER_KERNEL_IMAGE=/app/data/agent/firecracker-assets/vmlinux
# FIRECRACKER_ROOTFS_IMAGE=/app/data/agent/firecracker-assets/rootfs.ext4
# FIRECRACKER_SSH_KEY_PATH=/app/data/agent/firecracker-assets/id_rsa
# FIRECRACKER_ASSETS_DIR=./data/firecracker-assets
# FIRECRACKER_GUEST_USER=root
# FIRECRACKER_VCPU_COUNT=1
# FIRECRACKER_MEM_SIZE_MIB=512
# FIRECRACKER_BOOT_TIMEOUT_SECS=30
