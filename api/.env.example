# mymy API environment
# Copy to .env and adjust as needed

# PostgreSQL connection string.
# Inside docker-compose, use the service hostname "db".
DATABASE_URL=postgres://mymy:mymy@db:5432/mymy

# API listen port
PORT=33697

# CORS allowed origins (comma-separated). Web frontend origins.
CORS_ORIGIN=http://localhost:33696

# Set to true only when serving the API over HTTPS.
AUTH_COOKIE_SECURE=false

# Log level (trace, debug, info, warn, error)
RUST_LOG=mymy_api=info,tower_http=info
